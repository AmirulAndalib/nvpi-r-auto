{
  "version": "7.0.2.0",
  "description": "Revamped fork of Nvidia Profile Inspector with enhancements, UI fixes, and quality-of-life improvements.",
  "homepage": "https://github.com/xHybred/NvidiaProfileInspectorRevamped",
  "license": "MIT",
  "url": "https://github.com/xHybred/NvidiaProfileInspectorRevamped/releases/download/v7.0.2.0/NVPIRevamped.zip",
  "hash": "e86107a731d880df74c5682253d3db6fc760e4857237b0a6834e029f4f5bc02c",
  "bin": "NVPI-R.exe",
  "shortcuts": [
    [
      "NVPI-R.exe",
      "NVPI Revamped"
    ]
  ],
  "post_install": [
    "$currentDir = Join-Path (Split-Path $dir) 'current'",
    "$desktop = [Environment]::GetFolderPath('Desktop')",
    "$wsh = New-Object -ComObject WScript.Shell",
    "$lnk = $wsh.CreateShortcut(\"$desktop\\NVPI Revamped.lnk\")",
    "$lnk.TargetPath = \"$currentDir\\NVPI-R.exe\"",
    "$lnk.WorkingDirectory = \"$currentDir\"",
    "$lnk.Save()",
    "Get-ChildItem (Split-Path $dir) -Directory | Where-Object { $_.Name -ne 'current' -and $_.Name -ne $version } | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue"
  ],
  "pre_uninstall": [
    "$desktop = [Environment]::GetFolderPath('Desktop')",
    "Remove-Item \"$desktop\\NVPI Revamped.lnk\" -Force -ErrorAction SilentlyContinue"
  ],
  "persist": [
    "CustomSettingNames.xml",
    "Settings.xml",
    "Reference.xml"
  ],
  "notes": "Desktop and Start Menu shortcuts are created automatically. Settings are persisted across updates. Package maintained by AmirulAndalib (https://github.com/AmirulAndalib).",
  "checkver": {
    "github": "https://github.com/xHybred/NvidiaProfileInspectorRevamped"
  },
  "autoupdate": {
    "url": "https://github.com/xHybred/NvidiaProfileInspectorRevamped/releases/download/v$version/NVPIRevamped.zip"
  }
}