{
  "version": "3.0.1.11",
  "description": "Advanced Nvidia driver profile inspector and editor for Windows.",
  "homepage": "https://github.com/Orbmu2k/nvidiaProfileInspector",
  "license": "MIT",
  "url": "https://github.com/Orbmu2k/nvidiaProfileInspector/releases/download/v3.0.1.11/nvidiaProfileInspector.zip",
  "hash": "68db1640186dd6fd78b5f7949348808b9a542ee95e2a52810b2eeed026e80236",
  "bin": "nvidiaProfileInspector.exe",
  "shortcuts": [
    [
      "nvidiaProfileInspector.exe",
      "NVIDIA Profile Inspector"
    ]
  ],
  "post_install": [
    "$currentDir = Join-Path (Split-Path $dir) 'current'",
    "$desktop = [Environment]::GetFolderPath('Desktop')",
    "$wsh = New-Object -ComObject WScript.Shell",
    "$lnk = $wsh.CreateShortcut(\"$desktop\\NVIDIA Profile Inspector.lnk\")",
    "$lnk.TargetPath = \"$currentDir\\nvidiaProfileInspector.exe\"",
    "$lnk.WorkingDirectory = \"$currentDir\"",
    "$lnk.Save()",
    "Get-ChildItem (Split-Path $dir) -Directory | Where-Object { $_.Name -ne 'current' -and $_.Name -ne $version } | Remove-Item -Recurse -Force -ErrorAction SilentlyContinue"
  ],
  "pre_uninstall": [
    "$desktop = [Environment]::GetFolderPath('Desktop')",
    "Remove-Item \"$desktop\\NVIDIA Profile Inspector.lnk\" -Force -ErrorAction SilentlyContinue"
  ],
  "persist": "Reference.xml",
  "notes": "Desktop and Start Menu shortcuts are created automatically. Settings are persisted across updates. Package maintained by AmirulAndalib (https://github.com/AmirulAndalib).",
  "checkver": {
    "url": "https://api.github.com/repos/Orbmu2k/nvidiaProfileInspector/releases?per_page=1",
    "jsonpath": "$[0].tag_name",
    "regex": "v([\\d.]+)"
  },
  "autoupdate": {
    "url": "https://github.com/Orbmu2k/nvidiaProfileInspector/releases/download/v$version/nvidiaProfileInspector.zip"
  }
}